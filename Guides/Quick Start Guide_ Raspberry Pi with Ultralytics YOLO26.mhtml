import cv2<br>
from picamera2 import Picamera2</p>
<p dir=3D"auto">from ultralytics import YOLO</p>
<h1 dir=3D"auto">Initialize the Picamera2</h1>
<p dir=3D"auto">picam2 =3D Picamera2()<br>
picam2.preview_configuration.main.size =3D (1280, 720)<br>
picam2.preview_configuration.main.format =3D "RGB888"<br>
picam2.preview_configuration.align()<br>
picam2.configure("preview")<br>
picam2.start()</p>
<h1 dir=3D"auto">Load the YOLO11 model</h1>
<p dir=3D"auto">model =3D YOLO("yolo11n.pt")</p>
<p dir=3D"auto">while True:<br>
# Capture frame-by-frame<br>
frame =3D picam2.capture_array()</p>
<div class=3D"snippet-clipboard-content notranslate position-relative" data=
-snippet-clipboard-copy-content=3D"# Run YOLO11 inference on the frame
results =3D model(frame)

# Visualize the results on the frame
annotated_frame =3D results[0].plot()

# Display the resulting frame
cv2.imshow(&quot;Camera&quot;, annotated_frame)

# Break the loop if 'q' is pressed
if cv2.waitKey(1) =3D=3D ord(&quot;q&quot;):
    break"><pre class=3D"notranslate"><code class=3D"notranslate"># Run YOL=
